GROQ_API_KEY=

# "production" on Railway/server, "local" on dev machine
APP_ENV=production

# Local PostgreSQL (development only — leave unset on Railway)
LOCAL_DATABASE_URL=

# Production Supabase PostgreSQL
PROD_DATABASE_URL=

# Which sector this deployed instance sends (local | international | all).
# Set differently per Railway service; --sector CLI flag overrides this.
SECTOR=all

# SMTP (Gmail example — use an app password, not the account password)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
