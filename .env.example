GROQ_API_KEY=

# "production" on Railway/server, "local" on dev machine
APP_ENV=production

# Local PostgreSQL (development only — leave unset on Railway)
LOCAL_DATABASE_URL=

# Production Supabase PostgreSQL
PROD_DATABASE_URL=

# Which sector to send: auto | local | international | all.
# "auto" (default) picks based on the current PKT time — see main.py / railway.toml
# for the twice-daily cron schedule this is designed around.
SECTOR=auto

# SMTP (Gmail example — use an app password, not the account password)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_TO=
